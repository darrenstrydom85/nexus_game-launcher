# Twitch OAuth credentials — baked into the binary at compile time.
# Copy this file to .env and fill in your values from https://dev.twitch.tv/console
NEXUS_TWITCH_CLIENT_ID=your_twitch_client_id_here
# Optional: only needed for confidential (server-side) apps. Omit for public PKCE flow.
# NEXUS_TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# JSONBin.io key for version check (optional). Use ONE — Access Key (read-only) or Master Key. Used at compile time if set.
# Access Key: create with read permission at https://jsonbin.io/app/api-keys
# NEXUS_JSONBIN_ACCESS_KEY=your_jsonbin_access_key_here
# NEXUS_JSONBIN_MASTER_KEY=your_jsonbin_master_key_here
