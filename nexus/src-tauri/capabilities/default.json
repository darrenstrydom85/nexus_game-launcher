{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — grants filesystem, shell, process, and HTTP permissions with narrowly scoped access",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-set-focus",
    "core:event:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "/**" }]
    },
    "process:default",

    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "$APPDATA/nexus/**" }]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$APPDATA/nexus/**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$APPDATA/nexus/**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$APPDATA/nexus/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$APPDATA/nexus/**" }]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [{ "path": "$APPDATA/nexus/**" }]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [{ "path": "$APPDATA/nexus/**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$APPDATA/nexus/**" }]
    },

    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",

    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://www.steamgriddb.com/api/**" },
        { "url": "https://cdn2.steamgriddb.com/**" },
        { "url": "https://api.igdb.com/**" },
        { "url": "https://api.twitch.tv/**" },
        { "url": "https://id.twitch.tv/**" },
        { "url": "https://images.igdb.com/**" }
      ]
    }
  ]
}
